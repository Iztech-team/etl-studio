{
  "name": "etl-studio-root",
  "version": "1.0.0",
  "scripts": {
    "dev": "concurrently \"bun run backend\" \"bun run frontend\"",
    "backend": "cd backend && uvicorn main:app --reload --port 8000",
    "frontend": "cd frontend && bun run dev",
    "install:all": "pip install -r requirements.txt && cd frontend && bun install"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
